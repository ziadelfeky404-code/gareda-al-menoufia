{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/(.*)\\.(css|js|jpg|jpeg|png|gif|svg|ico|woff2|php)$", "dest": "/$1.$2" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
