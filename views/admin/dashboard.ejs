<%- include('../partials/admin-header', { title: title }) %>
<div class="admin-wrap">
<div class="container-fluid">
<div class="row">
<div class="col-12 mb-4">
<h1 class="admin-title"><i class="fas fa-tachometer-alt ms-2"></i> لوحة التحكم</h1>
</div>
</div>
<div class="row g-3 mb-4">
<div class="col-md-3">
<div class="stat-card">
<div class="stat-icon" style="background:#e8f5e9;color:#2e7d32"><i class="fas fa-newspaper"></i></div>
<div class="stat-body">
<h3><%= totalArticles %></h3>
<p>إجمالي المقالات</p>
</div>
</div>
</div>
<div class="col-md-3">
<div class="stat-card">
<div class="stat-icon" style="background:#e3f2fd;color:#1565c0"><i class="fas fa-tags"></i></div>
<div class="stat-body">
<h3><%= Object.keys(sectionCounts).length %></h3>
<p>الأقسام</p>
</div>
</div>
</div>
<div class="col-md-3">
<div class="stat-card">
<div class="stat-icon" style="background:#fff3e0;color:#e65100"><i class="fas fa-clock"></i></div>
<div class="stat-body">
<h3><%= recentArticles.length %></h3>
<p>آخر المقالات</p>
</div>
</div>
</div>
<div class="col-md-3">
<div class="stat-card">
<div class="stat-icon" style="background:#fce4ec;color:#c62828"><i class="fas fa-envelope"></i></div>
<div class="stat-body">
<h3><%= unreadMsgs %></h3>
<p>رسائل غير مقروءة</p>
</div>
</div>
</div>
</div>
<div class="row g-4">
<div class="col-lg-8">
<div class="admin-card">
<div class="card-header-custom">
<i class="fas fa-clock ms-2"></i> آخر المقالات المضافة
<a href="/admin/articles" class="btn-sm-link">عرض الكل <i class="fas fa-arrow-left"></i></a>
</div>
<div class="admin-table-wrap">
<table class="admin-table">
<thead><tr><th>#</th><th>العنوان</th><th>القسم</th><th>التاريخ</th><th>إجراءات</th></tr></thead>
<tbody>
<% for (var i = 0; i < recentArticles.length; i++) { var a = recentArticles[i]; %>
<tr>
<td><%= a.id %></td>
<td><a href="/article?id=<%= a.id %>" target="_blank"><%= a.title.substring(0, 50) %><% if (a.title.length > 50) { %>...<% } %></a></td>
<td><span class="badge-section"><%= a.section %></span></td>
<td style="font-size:12px;color:#888;font-weight:400"><%= a.date %></td>
<td class="actions-cell">
<a href="/admin/article-edit/<%= a.id %>" class="btn-action btn-edit" title="تعديل"><i class="fas fa-edit"></i></a>
</td>
</tr>
<% } %>
<% if (!recentArticles.length) { %>
<tr><td colspan="5" style="text-align:center;padding:30px;color:#999;font-weight:400">لا توجد مقالات</td></tr>
<% } %>
</tbody>
</table>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="admin-card">
<div class="card-header-custom">
<i class="fas fa-chart-pie ms-2"></i> توزيع المقالات
</div>
<div class="card-body-custom">
<% var secKeys = Object.keys(sectionCounts); %>
<% for (var si = 0; si < secKeys.length; si++) { var secName = secKeys[si]; var count = sectionCounts[secName]; var pct = totalArticles > 0 ? Math.round(count / totalArticles * 100) : 0; %>
<div class="section-stat-item">
<div class="section-stat-label">
<span><%= secName %></span>
<span class="badge-num"><%= count %></span>
</div>
<div class="progress-bar-wrap">
<div class="progress-fill" style="width:<%= pct %>%"></div>
</div>
</div>
<% } %>
</div>
</div>
<div class="admin-card mt-3">
<div class="card-header-custom">
<i class="fas fa-bolt ms-2"></i> إجراءات سريعة
</div>
<div class="card-body-custom d-flex gap-2 flex-wrap">
<a href="/admin/quick-add" class="btn btn-success btn-sm"><i class="fas fa-plus"></i> إضافة سريعة</a>
<a href="/admin/article-add" class="btn btn-primary btn-sm"><i class="fas fa-plus-circle"></i> إضافة مقال</a>
<a href="/admin/article-import" class="btn btn-info btn-sm text-white"><i class="fas fa-file-import"></i> استيراد</a>
<a href="/admin/sections" class="btn btn-warning btn-sm"><i class="fas fa-tags"></i> الأقسام</a>
<a href="/admin/homepage" class="btn btn-primary btn-sm" style="background:#1a5276"><i class="fas fa-home"></i> الصفحة الرئيسية</a>
<a href="/admin/section-order" class="btn btn-primary btn-sm" style="background:#6c3483"><i class="fas fa-sort"></i> ترتيب الأقسام</a>
<a href="/admin/settings" class="btn btn-secondary btn-sm"><i class="fas fa-cog"></i> الإعدادات</a>
<a href="/admin/messages" class="btn btn-danger btn-sm"><i class="fas fa-envelope"></i> الرسائل</a>
</div>
</div>
</div>
</div>
</div>
</div>
<%- include('../partials/admin-footer') %>