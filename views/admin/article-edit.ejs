<%- include('../partials/admin-header', { title: title }) %>
<style>
.form-group{margin-bottom:20px}
.form-group label{display:block;font-size:14px;font-weight:700;color:#333;margin-bottom:5px}
.form-group .form-control{border:2px solid #ddd;border-radius:6px;padding:10px 14px;font-size:14px;font-family:'Cairo',sans-serif;font-weight:400;width:100%}
.form-group .form-control:focus{border-color:#157039;box-shadow:0 0 0 3px rgba(21,112,57,0.1);outline:none}
.form-group textarea.form-control{resize:vertical;min-height:120px}
.form-group select.form-control{height:44px}
.form-help{font-size:11px;color:#888;font-weight:400;margin-top:3px}
.images-section{border:2px dashed #ddd;border-radius:8px;padding:20px;margin-bottom:20px;background:#fafafa}
.images-section .image-row{display:flex;gap:10px;margin-bottom:10px;align-items:center}
.images-section .image-row input{flex:1}
.images-section .image-row input[type="text"]{flex:2}
.btn-remove-image{background:#e74c3c;color:#fff;border:none;width:32px;height:32px;border-radius:4px;cursor:pointer;font-size:14px}
.btn-add-image{background:#157039;color:#fff;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font-size:13px;font-weight:700}
.current-image-preview{max-width:200px;margin-bottom:10px}
.current-image-preview img{width:100%;border-radius:4px;border:1px solid #ddd}
</style>
<div class="admin-wrap">
<div class="container-fluid">
<div class="row">
<div class="col-12 mb-4 d-flex justify-content-between align-items-center">
<h1 class="admin-title mb-0"><i class="fas fa-edit ms-2"></i> تعديل المقال #<%= id %></h1>
<a href="/article?id=<%= id %>" target="_blank" class="btn btn-outline-primary btn-sm"><i class="fas fa-external-link-alt"></i> معاينة</a>
</div>
</div>
<% if (message) { %>
<div class="alert alert-success"><i class="fas fa-check-circle ms-1"></i> <%= message %></div>
<% } %>
<% if (error) { %>
<div class="alert alert-danger"><i class="fas fa-exclamation-circle ms-1"></i> <%= error %></div>
<% } %>
<div class="admin-card">
<div class="card-body-custom">
<form method="post" action="/admin/article-edit/<%= id %>" enctype="multipart/form-data">
<div class="row">
<div class="col-md-8">
<div class="form-group">
<label>عنوان المقال <span style="color:red">*</span></label>
<input type="text" name="title" class="form-control" required value="<%= article.title || '' %>">
</div>
</div>
<div class="col-md-4">
<div class="form-group">
<label>القسم <span style="color:red">*</span></label>
<select name="section" class="form-control" required>
<% for (var i = 0; i < sections.length; i++) { var sName = typeof sections[i] === 'object' ? sections[i].name : sections[i]; %>
<option value="<%= sName %>" <%= article.section === sName ? 'selected' : '' %>><%= sName %></option>
<% } %>
</select>
</div>
</div>
</div>
<div class="row">
<div class="col-md-6">
<div class="form-group">
<label>الصورة الرئيسية</label>
<% if (article.image) { %><div class="current-image-preview"><img src="<%= article.image %>"></div><% } %>
<div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
<input type="text" name="image" class="form-control" placeholder="رابط URL الصورة" value="<%= article.image || '' %>" style="flex:1;min-width:150px">
<label style="background:#6c3483;color:#fff;padding:8px 14px;border-radius:6px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap"><i class="fas fa-upload ms-1"></i> رفع صورة<input type="file" name="image_file" accept="image/*" style="display:none"></label>
</div>
<div class="form-help">أدخل رابط URL أو ارفع صورة من جهازك. الأولوية للملف المرفوع.</div>
</div>
</div>
<div class="col-md-6">
<div class="form-group">
<label>صورة الغلاف</label>
<% if (article.cover_image) { %><div class="current-image-preview"><img src="<%= article.cover_image %>"></div><% } %>
<div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
<input type="text" name="cover_image" class="form-control" placeholder="رابط URL" value="<%= article.cover_image || '' %>" style="flex:1;min-width:150px">
<label style="background:#6c3483;color:#fff;padding:8px 14px;border-radius:6px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap"><i class="fas fa-upload ms-1"></i> رفع صورة<input type="file" name="cover_image_file" accept="image/*" style="display:none"></label>
</div>
</div>
</div>
</div>
<div class="form-group">
<label>محتوى المقال</label>
<textarea name="content" class="form-control" rows="10"><%= (article.paragraphs || []).join('\n') %></textarea>
<div class="form-help">كل سطر يمثل فقرة منفصلة</div>
</div>
<div class="row">
<div class="col-md-6">
<div class="form-group">
<label>الوسوم (tags)</label>
<input type="text" name="tags" class="form-control" placeholder="وسم1, وسم2, وسم3" value="<%= (article.tags || []).join(', ') %>">
</div>
</div>
<div class="col-md-6">
<div class="form-group">
<label>المؤلف</label>
<input type="text" name="author" class="form-control" placeholder="اسم المؤلف" value="<%= article.author || 'بوابة الجامعة' %>">
</div>
</div>
</div>
<div class="images-section" id="imagesSection">
<label style="display:block;font-size:14px;font-weight:700;color:#333;margin-bottom:10px"><i class="fas fa-images ms-1"></i> معرض الصور</label>
<div style="margin-bottom:8px;font-size:13px;color:#888"><i class="fas fa-info-circle ms-1"></i> يمكن إضافة صور متعددة دفعة واحدة من جهازك</div>
<% var galleries = article.images || []; if (galleries.length) { for (var gi = 0; gi < galleries.length; gi++) { var g = galleries[gi]; %>
<div class="image-row">
<input type="text" name="gallery_url[]" class="form-control" placeholder="رابط الصورة" value="<%= g.url || '' %>" style="flex:2">
<input type="text" name="gallery_desc[]" class="form-control" placeholder="وصف الصورة" value="<%= g.desc || '' %>" style="flex:1">
<% if (!g.url || g.url.indexOf('uploads/') !== 0) { %><button type="button" class="btn-remove-image" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button><% } %>
</div>
<% } } else { %>
<div class="image-row">
<input type="text" name="gallery_url[]" class="form-control" placeholder="رابط URL الصورة" style="flex:2">
<input type="text" name="gallery_desc[]" class="form-control" placeholder="وصف الصورة (اختياري)" style="flex:1">
</div>
<% } %>
<div style="display:flex;gap:5px;margin-top:8px;flex-wrap:wrap">
<label class="btn btn-secondary btn-sm" style="background:#6c3483;color:#fff;border:none;padding:7px 16px;border-radius:6px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:5px"><i class="fas fa-images"></i> رفع صور متعددة<input type="file" name="gallery_files" accept="image/*" multiple style="display:none"></label>
<button type="button" class="btn-add-image" onclick="addGalleryRow()"><i class="fas fa-plus"></i> إضافة رابط آخر</button>
</div>
</div>
<div class="d-flex gap-2">
<button type="submit" class="btn btn-primary" style="background:#157039;border:none;padding:12px 30px;font-size:16px;font-weight:800;border-radius:6px"><i class="fas fa-save ms-1"></i> حفظ التغييرات</button>
<a href="/admin/articles" class="btn btn-secondary" style="padding:12px 24px;font-size:14px;font-weight:700;border-radius:6px"><i class="fas fa-arrow-right ms-1"></i> عودة للمقالات</a>
</div>
</form>
</div>
</div>
</div>
</div>
<script>
function addGalleryRow() {
var section = document.getElementById('imagesSection');
var row = document.createElement('div');
row.className = 'image-row';
row.innerHTML = '<input type="text" name="gallery_url[]" class="form-control" placeholder="رابط الصورة"><input type="text" name="gallery_desc[]" class="form-control" placeholder="وصف الصورة (اختياري)"><button type="button" class="btn-remove-image" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>';
section.insertBefore(row, section.lastElementChild);
}
</script>
<%- include('../partials/admin-footer') %>