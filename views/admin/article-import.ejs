<%- include('../partials/admin-header', { title: title }) %>
<style>
.import-section{border:2px dashed #ddd;border-radius:8px;padding:30px;background:#fafafa;text-align:center}
.import-section .import-icon{font-size:48px;color:#157039;margin-bottom:15px}
.import-section h4{font-size:18px;font-weight:800;color:#333;margin-bottom:10px}
.import-section p{font-size:14px;color:#666;font-weight:400;margin-bottom:20px}
.import-section .file-input-wrap{display:flex;flex-direction:column;align-items:center;gap:12px}
.import-section .file-input-wrap input[type="file"]{max-width:300px}
.import-section .file-input-wrap .form-control-file{padding:10px;border:2px solid #ddd;border-radius:6px;background:#fff;font-family:'Cairo',sans-serif}
.import-section .btn-import{background:#157039;color:#fff;border:none;padding:12px 40px;border-radius:6px;font-size:16px;font-weight:800;cursor:pointer;transition:background 0.2s}
.import-section .btn-import:hover{background:#0f5a2d}
.formats-info{text-align:right;margin-top:15px;padding:12px 15px;background:#fff;border-radius:6px;font-size:12px;color:#888;font-weight:400}
.formats-info strong{color:#333}
.alert-success{background:#d4edda;color:#155724;padding:15px;border-radius:6px;font-size:14px;font-weight:400;margin-bottom:20px}
.alert-danger{background:#f8d7da;color:#721c24;padding:15px;border-radius:6px;font-size:14px;font-weight:400;margin-bottom:20px}
</style>
<div class="admin-wrap">
<div class="container-fluid">
<div class="row">
<div class="col-12 mb-4">
<h1 class="admin-title"><i class="fas fa-file-import ms-2"></i> استيراد مقال</h1>
</div>
</div>
<% if (message) { %>
<div class="alert-success"><i class="fas fa-check-circle ms-1"></i> <%= message %></div>
<% } %>
<% if (error) { %>
<div class="alert-danger"><i class="fas fa-exclamation-circle ms-1"></i> <%= error %></div>
<% } %>
<div class="admin-card">
<div class="card-body-custom">
<form method="post" action="/admin/article-import" enctype="multipart/form-data">
<div class="row mb-3">
<div class="col-md-6">
<div class="form-group">
<label style="font-size:14px;font-weight:700;color:#333;display:block;margin-bottom:5px">القسم</label>
<select name="section" class="form-control" style="padding:8px 12px;border:2px solid #ddd;border-radius:6px;font-size:14px;font-family:'Cairo',sans-serif;width:100%">
<% for (var i = 0; i < sections.length; i++) { var sName = typeof sections[i] === 'object' ? sections[i].name : sections[i]; %>
<option value="<%= sName %>"><%= sName %></option>
<% } %>
</select>
</div>
</div>
</div>
<div class="import-section">
<div class="import-icon"><i class="fas fa-file-upload"></i></div>
<h4>رفع ملف Word أو PDF</h4>
<p>اختر ملف Word (.docx) أو PDF لاستخراج المحتوى تلقائياً</p>
<div class="file-input-wrap">
<input type="file" name="article_file" accept=".docx,.pdf" class="form-control-file" required>
<button type="submit" class="btn-import"><i class="fas fa-upload ms-1"></i> استيراد</button>
</div>
<div class="formats-info">
<strong>الصيغ المدعومة:</strong> Word (.docx) — PDF (.pdf)<br>
<strong>ملاحظة:</strong> يتم استخراج النصوص والصور من الملف تلقائياً
</div>
</div>
</form>
</div>
</div>
</div>
</div>
<%- include('../partials/admin-footer') %>