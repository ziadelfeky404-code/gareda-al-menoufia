<%- include('../partials/admin-header', { title: title }) %>
<style>
.message-card{border:1px solid #eee;border-radius:8px;margin-bottom:12px;padding:18px 20px;background:#fff;transition:box-shadow 0.2s}
.message-card:hover{box-shadow:0 2px 8px rgba(0,0,0,0.06)}
.message-card .msg-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.message-card .msg-header h4{font-size:15px;font-weight:800;color:#333;margin:0}
.message-card .msg-header .msg-date{font-size:11px;color:#999;font-weight:400}
.message-card .msg-meta{font-size:12px;color:#666;font-weight:400;margin-bottom:8px}
.message-card .msg-meta i{margin-left:4px;color:#157039}
.message-card .msg-body{font-size:14px;color:#555;font-weight:400;line-height:1.7;padding:12px;background:#fafafa;border-radius:6px;border-right:3px solid #157039}
.message-card .msg-actions{margin-top:10px;text-align:left}
.empty-state{text-align:center;padding:60px 20px;color:#999}
.empty-state i{font-size:48px;color:#ddd;margin-bottom:15px}
.empty-state h4{font-size:18px;font-weight:700;color:#666}
</style>
<div class="admin-wrap">
<div class="container-fluid">
<div class="row">
<div class="col-12 mb-4">
<h1 class="admin-title"><i class="fas fa-envelope ms-2"></i> الرسائل (<%= msgs.length %>)</h1>
</div>
</div>
<% if (msgs.length === 0) { %>
<div class="empty-state">
<i class="far fa-envelope-open"></i>
<h4>لا توجد رسائل حتى الآن</h4>
</div>
<% } else { for (var mi = msgs.length - 1; mi >= 0; mi--) { var m = msgs[mi]; %>
<div class="message-card" style="<%= m.read ? 'opacity:0.6' : 'border-right:4px solid #157039' %>">
<div class="msg-header">
<h4><i class="fas fa-user ms-1"></i> <%= m.name || 'غير معروف' %></h4>
<span class="msg-date"><i class="far fa-clock ms-1"></i> <%= m.date || '' %></span>
</div>
<div class="msg-meta">
<i class="fas fa-envelope ms-1"></i> <a href="mailto:<%= m.email %>"><%= m.email %></a>
</div>
<div class="msg-body"><%= m.message %></div>
<div class="msg-actions">
<% if (!m.read) { %>
<a href="/admin/messages?mark=<%= m.id %>" class="btn btn-sm btn-outline-success"><i class="fas fa-check ms-1"></i> تحديد كمقروء</a>
<% } %>
<a href="/admin/messages?delete=<%= m.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('حذف هذه الرسالة؟')"><i class="fas fa-trash ms-1"></i> حذف</a>
</div>
</div>
<% } } %>
</div>
</div>
<%- include('../partials/admin-footer') %>