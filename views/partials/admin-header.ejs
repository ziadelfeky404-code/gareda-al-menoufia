<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
<title><%= typeof title !== 'undefined' ? title + ' - ' + getSetting('site_name', 'جامعة المنوفية') : getSetting('site_name', 'جامعة المنوفية') + ' | الإدارة' %></title>
<link rel="icon" type="image/png" href="<%= getSetting('favicon_url') %>">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--fonts:'Cairo',sans-serif;--red:#157039;--red-dark:#0f5a2d;--dark:#091e3a;--gray-light:#818b9d;--white:#fff}
body{font-family:var(--fonts);font-size:14px;text-align:right;background:#f4f6f9;color:#333;font-weight:500}
.admin-topbar{background:var(--dark);color:var(--white);padding:10px 0;position:sticky;top:0;z-index:9999}
.admin-topbar .admin-brand{font-size:18px;font-weight:900;color:var(--white)}
.admin-topbar .admin-brand i{color:var(--red)}
.admin-topbar a{color:rgba(255,255,255,0.8);font-size:13px;font-weight:600;text-decoration:none;margin:0 8px;transition:color 0.2s}
.admin-topbar a:hover{color:var(--white)}
.admin-wrap{padding:25px 0}
.container-fluid{max-width:1300px;margin:0 auto;padding:0 20px}
.admin-title{font-size:24px;font-weight:900;color:var(--dark);margin-bottom:20px}
.admin-card{background:var(--white);border-radius:8px;box-shadow:0 1px 4px rgba(0,0,0,0.06);margin-bottom:25px;overflow:hidden}
.card-header-custom{background:var(--white);padding:15px 20px;border-bottom:1px solid #eee;font-size:15px;font-weight:800;color:var(--dark);display:flex;justify-content:space-between;align-items:center}
.card-body-custom{padding:20px}
.admin-table-wrap{overflow-x:auto}
.admin-table{width:100%;border-collapse:collapse;font-size:13px}
.admin-table th{background:#f8f9fa;color:#555;font-weight:800;padding:11px 14px;text-align:right;border-bottom:2px solid #eee;font-size:12px;white-space:nowrap}
.admin-table td{padding:10px 14px;border-bottom:1px solid #f0f0f0;vertical-align:middle}
.admin-table tr:hover{background:#fafafa}
.stat-card{background:var(--white);border-radius:8px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.06);display:flex;align-items:center;gap:16px;transition:transform 0.2s}
.stat-card:hover{transform:translateY(-2px)}
.stat-card .stat-icon{width:50px;height:50px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.stat-card .stat-body h3{font-size:24px;font-weight:900;color:var(--dark);margin:0;line-height:1}
.stat-card .stat-body p{font-size:12px;color:var(--gray-light);font-weight:400;margin:3px 0 0}
.badge-section{display:inline-block;background:#e8f5e9;color:#2e7d32;font-size:11px;font-weight:700;padding:3px 10px;border-radius:4px}
.actions-cell{white-space:nowrap}
.btn-action{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:4px;font-size:13px;transition:all 0.2s;text-decoration:none;margin:0 2px}
.btn-edit{background:#fff3e0;color:#e65100}
.btn-edit:hover{background:#ffe0b2;color:#bf360c}
.btn-view{background:#e3f2fd;color:#1565c0}
.btn-view:hover{background:#bbdefb;color:#0d47a1}
.btn-delete{background:#fce4ec;color:#c62828}
.btn-delete:hover{background:#f8bbd0;color:#b71c1c}
.btn-sm-link{font-size:12px;color:var(--red);font-weight:700;text-decoration:none}
.btn-sm-link:hover{text-decoration:underline}
.alert{font-size:14px;font-weight:400;border-radius:6px;padding:12px 18px;margin-bottom:20px}
.progress-bar-wrap{height:6px;background:#eee;border-radius:3px;overflow:hidden;margin-top:5px}
.progress-fill{height:100%;background:#157039;border-radius:3px;transition:width 0.3s}
.section-stat-item{margin-bottom:12px}
.section-stat-label{display:flex;justify-content:space-between;font-size:13px;font-weight:600;color:#555}
.section-stat-label .badge-num{background:var(--red);color:var(--white);padding:1px 10px;border-radius:10px;font-size:11px}
.admin-sidebar{position:sticky;top:70px}
.nav-link-admin{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:6px;color:#555;font-size:14px;font-weight:600;transition:all 0.2s;text-decoration:none;margin-bottom:2px}
.nav-link-admin:hover,.nav-link-admin.active{background:#e8f5e9;color:#157039}
.nav-link-admin i{width:20px;text-align:center}
.admin-quick-bar{display:flex;gap:4px;flex-wrap:wrap;background:#f8f9fa;padding:8px 15px;border-radius:6px;margin-bottom:20px;border:1px solid #eee}
.admin-quick-bar a{font-size:12px;font-weight:700;padding:5px 12px;border-radius:4px;color:#555;text-decoration:none;transition:all 0.2s;white-space:nowrap}
.admin-quick-bar a:hover{background:#e8f5e9;color:#157039}
.admin-quick-bar a i{margin-left:4px}
.search-input{display:inline-flex;align-items:center;gap:6px;background:#fff;border:2px solid #ddd;border-radius:6px;padding:2px 10px}
.search-input input{border:none;padding:5px;font-size:13px;font-family:'Cairo',sans-serif;width:200px;outline:none;background:transparent}
.search-input input:focus+.search-icon,.search-input:hover{border-color:#157039}
.search-input .search-icon{color:#aaa}
.date-badge{background:#e8f5e9;color:#2e7d32;font-size:11px;padding:2px 8px;border-radius:3px}
.empty-state-admin{text-align:center;padding:40px 20px;color:#999;font-size:14px;font-weight:400}
.empty-state-admin i{font-size:40px;color:#ddd;display:block;margin-bottom:10px}
@media(max-width:991px){
.admin-topbar .admin-brand{font-size:15px}
.admin-topbar a{font-size:11px!important;padding:3px 4px!important;margin:0 2px!important}
}
@media(max-width:767px){
.admin-title{font-size:18px!important}
.admin-quick-bar{overflow-x:auto;flex-wrap:nowrap;justify-content:flex-start;padding:6px 10px}
.admin-quick-bar a{font-size:10px!important;padding:3px 6px!important;white-space:nowrap}
.stat-card{padding:12px}
.stat-card .stat-icon{width:36px;height:36px;font-size:16px}
.stat-card .stat-body h3{font-size:18px}
.admin-table{font-size:11px}
.admin-table th,.admin-table td{padding:6px 8px!important}
.admin-table td a{font-size:11px!important}
.admin-topbar .container-fluid>div:last-child{overflow-x:auto;display:flex;flex-wrap:nowrap;width:100%;padding-bottom:4px}
.admin-topbar a{font-size:10px!important;padding:2px 6px!important}
.row.g-4 .col-lg-4{margin-top:0}
.homepage-section .section-body{padding:10px!important}
.position-row{flex-wrap:wrap;gap:4px}
.position-row input{font-size:12px!important;min-width:60px!important}
}
@media(max-width:480px){
.admin-title{font-size:16px!important}
.stat-card .stat-body h3{font-size:16px}
.stat-card .stat-body p{font-size:10px}
.admin-table{font-size:10px}
.admin-table th,.admin-table td{padding:4px 5px!important}
.admin-table td img{width:30px!important;height:25px!important}
}
</style>
</head>
<body>
<div class="admin-topbar">
<div class="container-fluid d-flex justify-content-between align-items-center flex-wrap" style="gap:4px">
<div class="admin-brand"><i class="fas fa-crown ms-1"></i> <%= getSetting('site_name') %></div>
<div class="d-flex align-items-center flex-wrap" style="gap:2px">
<a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> الرئيسية</a>
<a href="/admin/quick-add"><i class="fas fa-plus-circle"></i> إضافة سريعة</a>
<a href="/admin/article-add"><i class="fas fa-plus"></i> مقال</a>
<a href="/admin/articles"><i class="fas fa-newspaper"></i> المقالات</a>
<a href="/admin/homepage"><i class="fas fa-home"></i> الصفحة الرئيسية</a>
<a href="/admin/section-order"><i class="fas fa-sort"></i> ترتيب</a>
<a href="/admin/sections"><i class="fas fa-tags"></i> أقسام</a>
<a href="/admin/settings"><i class="fas fa-cog"></i> إعدادات</a>
<a href="/admin/messages"><i class="fas fa-envelope"></i> رسائل</a>
<a href="/" target="_blank"><i class="fas fa-external-link-alt"></i> الموقع</a>
<a href="/admin/logout" style="margin-right:5px;color:#e74c3c"><i class="fas fa-sign-out-alt"></i> خروج</a>
</div>
</div>
</div>