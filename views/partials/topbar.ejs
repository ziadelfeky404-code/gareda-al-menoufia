<section class="top-bar">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="top-links">
                    <span id="headerDate" class="ms-1"></span>
                    <span class="divider">|</span>
                    <a href="/contact">اتصل بنا</a>
                    <a href="<%= getSetting('facebook_url') %>" class="social-icon" target="_blank"><i class="fab fa-facebook-f"></i></a>
                    <a href="<%= getSetting('twitter_url') %>" class="social-icon" target="_blank"><i class="fab fa-twitter"></i></a>
                    <a href="<%= getSetting('youtube_url') %>" class="social-icon" target="_blank"><i class="fab fa-youtube"></i></a>
                    <a href="<%= getSetting('instagram_url') %>" class="social-icon" target="_blank"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
        </div>
        <div class="row align-items-start py-2 header-main-row">
            <!-- University logo (right) -->
            <div class="col-3 col-md-3 d-flex justify-content-start">
                <a href="/">
                    <img src="<%= getSetting('logo_url') %>" alt="<%= getSetting('site_name') %>" class="header-logo-img" style="height:100px;width:auto;max-width:100%;">
                </a>
            </div>
            <!-- Editorial info (between logo and jubilee) -->
            <div class="col-2 col-md-2 d-flex flex-column align-items-center justify-content-center text-center" style="font-size:11px;line-height:1.5;color:#555;font-weight:400;font-family:'Cairo',sans-serif;">
                <div style="font-weight:700;color:var(--dark);font-size:12px;margin-bottom:2px;">إعداد وتحرير</div>
                <div>طلاب قسم الإعلام</div>
                <div>دفعة ٢٠٢٥-٢٠٢٦م</div>
                <div style="margin-top:3px;font-size:10px;color:#888;">صحيفة تدريبية سنوية خاصة</div>
                <div style="font-size:10px;color:#888;">عن اليوبيل الذهبي الـ ٥٠</div>
                <div style="font-size:10px;color:#888;">لجامعة المنوفية</div>
            </div>
            <!-- Jubilee image (center) -->
            <div class="col-2 col-md-2 d-flex flex-column align-items-center">
                <img src="/uploads/WhatsApp Image 2026-05-22 at 4.46.05 AM.jpeg" alt="اليوبيل الذهبي" class="header-jubilee-img" style="height:70px;width:auto;max-height:55px;">
                <div style="font-size:13px;font-weight:800;color:var(--red);margin-top:3px;">اليوبيل الذهبي</div>
            </div>
            <!-- Supervision info (between jubilee and college logo) -->
            <div class="col-3 col-md-3 d-flex flex-column align-items-center justify-content-center text-center" style="font-size:11px;line-height:1.5;color:#555;font-weight:400;font-family:'Cairo',sans-serif;">
                <div style="font-weight:700;color:var(--dark);font-size:12px;margin-bottom:3px;">إشراف</div>
                <div>أ.د عبدالخالق زقزوق</div>
                <div>أ.د هشام رشدي</div>
                <div style="margin-top:5px;padding-top:3px;border-top:1px solid #ddd;">
                    <div style="font-weight:700;color:var(--dark);font-size:11px;">رئيس مجلس الإدارة</div>
                    <div>أ.د عصام شوقي شبل</div>
                </div>
                <div style="margin-top:3px;">
                    <div style="font-weight:700;color:var(--dark);font-size:11px;">رئيس التحرير</div>
                    <div>أ.د محمد زيدان عبدالحميد</div>
                </div>
            </div>
            <!-- College logo (left) -->
            <div class="col-2 col-md-2 d-flex justify-content-end">
                <img src="/uploads/EDV_ar-removebg-preview.png" alt="شعار الكلية" class="header-college-img" style="height:80px;width:auto;max-height:60px;">
            </div>
        </div>
    </div>
</section>