<section class="nav-section" style="position:sticky;top:0;z-index:999999">
    <nav class="navbar navbar-expand">
        <div class="container">
            <div class="d-flex align-items-center w-100" id="mainNav">
                <ul class="navbar-nav ms-auto flex-nowrap nav-scroll">
                    <li class="nav-item"><a class="nav-link" href="/">الرئيسية</a></li>
                    <% var navSecs = getSections(); for (var i = 0; i < navSecs.length; i++) { var ns = navSecs[i]; %>
                    <li class="nav-item"><a class="nav-link" href="/section?slug=<%= ns.slug %>"><%= ns.name %></a></li>
                    <% } %>
                </ul>
                <div class="search-box me-2 flex-shrink-0">
                    <button type="button" onclick="var q=this.nextElementSibling.value;if(q.trim())window.location='/search?q='+encodeURIComponent(q.trim())"><i class="fas fa-search"></i></button>
                    <input type="text" class="searchInput" placeholder="بحث...">
                </div>
            </div>
        </div>
    </nav>
</section>
<% if (isAdmin) { %>
<div class="admin-bar" style="background:#091e3a;color:#ccc;padding:6px 0;font-size:12px;text-align:center;font-weight:400">
    <i class="fas fa-user-shield"></i> أنت مسجل كمدير —
    <a href="/admin/quick-add" style="color:#fff;font-weight:700;margin:0 8px"><i class="fas fa-plus-circle"></i> إضافة مقال</a>
    <span style="opacity:0.3;margin:0 4px">|</span>
    <a href="/admin/dashboard" style="color:#fff;font-weight:700;margin:0 8px"><i class="fas fa-tachometer-alt"></i> لوحة التحكم</a>
    <span style="opacity:0.3;margin:0 4px">|</span>
    <a href="/admin/logout" style="color:#fff;font-weight:700;margin:0 8px"><i class="fas fa-sign-out-alt"></i> تسجيل الخروج</a>
</div>
<% } %>
