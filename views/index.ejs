                                <p style="font-size:13px;color:var(--gray-light);font-weight:400;margin-bottom:0;"><%= (a0.paragraphs && a0.paragraphs[0] ? a0.paragraphs[0].substring(0, 100) : '') %>...</p>
                            </div>
                        </div>
                    </div>
