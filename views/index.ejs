                                <img src="<%= a2.image || '' %>" alt="<%= a2.title || '' %>" style="width:100%;height:180px;object-fit:cover;transition:transform 0.3s;">
                            </div>
                            <div class="card-body" style="padding:10px 0;">
                                <h3 style="font-size:16px;font-weight:800;line-height:1.4;margin-bottom:5px;"><a href="/article?id=<%= a2.id %>" style="color:var(--dark);"><%= a2.title %></a></h3>
                                <p style="font-size:13px;color:var(--gray-light);font-weight:400;margin-bottom:0;"><%= (a2.paragraphs && a2.paragraphs[0] ? a2.paragraphs[0].substring(0, 100) : '') %>...</p>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
                <div class="row mt-2">
                    <% var a3 = akhbarArts[3]; if (a3) { %>
                    <div class="col-md-6">
                        <div class="list-news-item" style="display:flex;gap:12px;margin-bottom:15px;padding-bottom:15px;border-bottom:1px solid #eee;">
                            <img src="<%= a3.image || '' %>" alt="<%= a3.title || '' %>" style="width:120px;height:80px;object-fit:cover;flex-shrink:0;">
                            <div>
                                <h4 style="font-size:14px;font-weight:700;line-height:1.4;margin:0;"><a href="/article?id=<%= a3.id %>" style="color:var(--dark);"><%= a3.title %></a></h4>
                                <div class="list-date" style="font-size:11px;color:var(--gray-light);font-weight:400;margin-top:4px;"><%= a3.date || '' %></div>
                            </div>
                        </div>
                    </div>
                    <% } %>
                    <% var a4 = akhbarArts[4]; if (a4) { %>
                    <div class="col-md-6">
                        <div class="list-news-item" style="display:flex;gap:12px;margin-bottom:15px;padding-bottom:15px;border-bottom:1px solid #eee;">
                            <img src="<%= a4.image || '' %>" alt="<%= a4.title || '' %>" style="width:120px;height:80px;object-fit:cover;flex-shrink:0;">
                            <div>
                                <h4 style="font-size:14px;font-weight:700;line-height:1.4;margin:0;"><a href="/article?id=<%= a4.id %>" style="color:var(--dark);"><%= a4.title %></a></h4>
                                <div class="list-date" style="font-size:11px;color:var(--gray-light);font-weight:400;margin-top:4px;"><%= a4.date || '' %></div>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="sidebar-box" style="background:#fafafa;border:1px solid #e8e8e8;margin-bottom:20px;">
                    <div class="sidebar-header" style="background:var(--dark);color:var(--white);padding:10px 15px;font-size:17px;font-weight:800;">الأكثر قراءة</div>
                    <div class="sidebar-body" style="padding:12px;">
                        <% var num = 1; for (var mi = 0; mi < mostReadArticles.length; mi++) { var mra = mostReadArticles[mi]; %>
                        <div class="urgent-item" style="padding:10px 0;border-bottom:1px solid #eee;display:flex;gap:10px;align-items:flex-start;">
                            <span class="urgent-num" style="background:var(--red);color:var(--white);width:26px;height:26px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;flex-shrink:0;margin-top:2px;"><%= num++ %></span>
                            <h5 style="font-size:13px;font-weight:700;line-height:1.4;margin:0;"><a href="/article?id=<%= mra.id %>" style="color:var(--dark);"><%= mra.title %></a></h5>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

