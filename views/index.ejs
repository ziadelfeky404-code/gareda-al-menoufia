            </h2>
            <a href="/section?slug=akhbar" class="section-more" style="font-size:14px;color:var(--red);font-weight:600;">المزيد <i class="fas fa-arrow-left me-1"></i></a>
        </div>
        <div class="row">
            <div class="col-lg-8">
                <div class="row">
                    <% var a0 = akhbarArts[0]; if (a0) { %>
                    <div class="col-md-4">
                        <div class="news-card" style="margin-bottom:20px;transition:transform 0.2s;">
                            <div class="card-img" style="position:relative;overflow:hidden;">
                                <span class="card-badge" style="position:absolute;top:10px;right:10px;background:var(--red);color:var(--white);font-size:12px;font-weight:600;padding:3px 10px;font-family:'Cairo',sans-serif;"><%= (a0.tags && a0.tags[0]) || '' %></span>
                                <img src="<%= a0.image || '' %>" alt="<%= a0.title || '' %>" style="width:100%;height:180px;object-fit:cover;transition:transform 0.3s;">
                            </div>
                            <div class="card-body" style="padding:10px 0;">
