                        <div class="news-card" style="margin-bottom:20px;transition:transform 0.2s;">
                            <div class="card-img" style="position:relative;overflow:hidden;">
                                <span class="card-badge" style="position:absolute;top:10px;right:10px;background:var(--red);color:var(--white);font-size:12px;font-weight:600;padding:3px 10px;font-family:'Cairo',sans-serif;"><%= (a1.tags && a1.tags[0]) || '' %></span>
                                <img src="<%= a1.image || '' %>" alt="<%= a1.title || '' %>" style="width:100%;height:180px;object-fit:cover;transition:transform 0.3s;">
                            </div>
                            <div class="card-body" style="padding:10px 0;">
                                <h3 style="font-size:16px;font-weight:800;line-height:1.4;margin-bottom:5px;"><a href="/article?id=<%= a1.id %>" style="color:var(--dark);"><%= a1.title %></a></h3>
                                <p style="font-size:13px;color:var(--gray-light);font-weight:400;margin-bottom:0;"><%= (a1.paragraphs && a1.paragraphs[0] ? a1.paragraphs[0].substring(0, 100) : '') %>...</p>
                            </div>
                        </div>
                    </div>
                    <% } %>
                    <% var a2 = akhbarArts[2]; if (a2) { %>
