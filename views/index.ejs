<%- include('partials/header', { title: 'بوابة جامعة المنوفية الإخبارية' }) %>
<%- include('partials/topbar') %>
<%- include('partials/navbar') %>
<style>@keyframes tickerScroll{0%{transform:translateX(0)}100%{transform:translateX(-100%)}}</style>

<!-- ===== BREAKING TICKER ===== -->
<% if (tickerArticles && tickerArticles.length) { %>
<section class="ticker-section" style="background:var(--gray);color:var(--white);margin-top:5px;margin-bottom:10px;">
    <div class="container">
        <div class="row">
            <div class="col-12 d-flex" style="overflow:hidden;">
                <div class="ticker-label" style="background:var(--red);padding:8px 20px;font-weight:800;font-size:16px;white-space:nowrap;flex-shrink:0;">عاجل</div>
                <div class="ticker-content" style="overflow:hidden;padding:8px 0;flex:1;position:relative;">
                    <div class="ticker-track" style="display:flex;white-space:nowrap;animation:tickerScroll 25s linear infinite;width:max-content;padding-right:100%;" onmouseover="this.style.animationPlayState='paused'" onmouseout="this.style.animationPlayState='running'">
                        <% for (var i = 0; i < tickerArticles.length; i++) { var ta = tickerArticles[i]; %>
                        <% if (i > 0) { %><span class="ticker-dot" style="margin:0 12px;color:#ccc;">|</span><% } %>
                        <a href="/article?id=<%= ta.id %>" style="color:var(--white);font-size:15px;font-weight:500;text-decoration:none;display:inline-block;"><%= ta.title %></a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- ===== HERO SECTION ===== -->
<section class="hero-section" style="margin-top:15px;">
    <div class="container">
        <div class="row g-2">
<div class="col-lg-6 mb-2 mb-lg-0 d-flex flex-column" id="heroSlideshow">
    <% for (var si = 0; si < heroSlides.length; si++) { var slide = heroSlides[si]; %>
    <div class="hero-main" data-slide="<%= si %>" data-pin-pos="hero_slide_<%= si %>" style="position:relative;overflow:hidden;flex:1;min-height:380px;transition:transform 0.3s ease;<%= si > 0 ? 'display:none' : '' %>">
        <% if (slide) { %>
        <img src="<%= slide.image || '' %>" alt="<%= slide.title || '' %>" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s ease;">
        <div class="hero-overlay" style="position:absolute;bottom:0;left:0;right:0;padding:30px;background:linear-gradient(0deg,rgba(0,0,0,0.95) 0%,rgba(0,0,0,0.7) 40%,rgba(0,0,0,0) 100%);">
            <div class="hero-category" style="font-size:13px;font-weight:400;color:var(--white);font-family:'Cairo',sans-serif;margin-bottom:5px;"><%= slide.section || '' %><div style="width:40px;height:3px;background:var(--red);margin-top:4px;"></div></div>
            <h2 style="color:var(--white);font-size:26px;font-weight:800;line-height:1.3;margin-top:8px;"><a href="/article?id=<%= slide.id || 0 %>" style="color:inherit;"><%= slide.title || '' %></a></h2>
        </div>
        <% if (isAdmin) { %>
        <div style="position:absolute;top:4px;left:4px;background:#e74c3c;color:#fff;border-radius:4px;padding:1px 6px;font-size:10px;z-index:20;font-weight:700">#<%= slide.id || '?' %></div>
        <div onclick="editHeroPin(this.parentElement, 'hero_slide_<%= si %>')" style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.7);color:#fff;border-radius:4px;padding:2px 8px;font-size:11px;cursor:pointer;opacity:0;z-index:20;transition:opacity 0.3s" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0'" class="hero-edit-btn"><i class="fas fa-pen"></i> تغيير</div>
        <% } %>
        <% } else { %>
        <div style="width:100%;height:380px;background:#eee;display:flex;align-items:center;justify-content:center;color:#ccc;font-weight:400">لا يوجد مقال</div>
        <% } %>
    </div>
    <% } %>
    <div style="display:flex;justify-content:center;gap:6px;margin-top:8px">
        <% for (var di = 0; di < heroSlides.length; di++) { %>
        <span class="slide-dot" data-idx="<%= di %>" style="width:10px;height:10px;border-radius:50%;background:<%= di == 0 ? '#e74c3c' : 'rgba(0,0,0,0.2)' %>;cursor:pointer;transition:all 0.3s"></span>
        <% } %>
    </div>
</div>
<div class="col-lg-3 col-md-6 mb-2 mb-lg-0 d-flex"><div class="hero-side" style="display:flex;flex-direction:column;flex:1;">
    <% for (var hi = 0; hi < 2; hi++) { var ha = heroArts[hi]; %>
    <div class="hero-side-item<%= hi == 0 ? ' mb-2' : '' %>" data-pin-pos="hero_<%= hi %>" style="position:relative;flex:1;overflow:hidden;min-height:180px;">
        <% if (ha) { %>
        <img src="<%= ha.image || '' %>" alt="<%= ha.title || '' %>" style="width:100%;height:100%;object-fit:cover;">
        <div class="hero-overlay" style="position:absolute;bottom:0;left:0;right:0;padding:15px;background:linear-gradient(0deg,rgba(0,0,0,0.95) 0%,rgba(0,0,0,0.7) 40%,rgba(0,0,0,0) 100%);">
            <div class="hero-category" style="font-size:13px;font-weight:400;color:var(--white);font-family:'Cairo',sans-serif;margin-bottom:5px;"><%= ha.section || '' %><div style="width:25px;height:3px;background:var(--red);margin-top:4px;"></div></div>
            <h2 style="color:var(--white);font-size:15px;font-weight:800;line-height:1.3;margin-top:3px;"><a href="/article?id=<%= ha.id || 0 %>" style="color:inherit;"><%= ha.title || '' %></a></h2>
        </div>
        <% if (isAdmin) { %>
        <div style="position:absolute;top:4px;left:4px;background:#e74c3c;color:#fff;border-radius:4px;padding:1px 6px;font-size:10px;z-index:20;font-weight:700">#<%= ha.id || '?' %></div>
        <div onclick="editHeroPin(this.parentElement, 'hero_<%= hi %>')" style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.7);color:#fff;border-radius:4px;padding:2px 8px;font-size:11px;cursor:pointer;opacity:0;z-index:20;transition:opacity 0.3s" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0'" class="hero-edit-btn"><i class="fas fa-pen"></i> تغيير</div>
        <% } %>
        <% } else { %>
        <div style="width:100%;height:100%;min-height:180px;background:#eee;display:flex;align-items:center;justify-content:center;color:#ccc;font-weight:400">لا يوجد مقال</div>
        <% } %>
    </div>
    <% } %>
</div></div>
<div class="col-lg-3 col-md-6 d-flex"><div class="hero-side" style="display:flex;flex-direction:column;flex:1;">
    <% for (var hi = 2; hi < 4; hi++) { var ha = heroArts[hi]; %>
